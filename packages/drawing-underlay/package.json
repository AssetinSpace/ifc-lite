{
  "name": "@ifc-lite/drawing-underlay",
  "version": "0.1.0",
  "description": "Georeferenced 2D drawing underlays (PDF floor plans) for IFC models - 2-point calibration, storey placement, and a WebGPU textured-plane pipeline",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsc --watch",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.71",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "license": "MPL-2.0",
  "author": "Louis True",
  "repository": {
    "type": "git",
    "url": "https://github.com/LTplus-AG/ifc-lite.git",
    "directory": "packages/drawing-underlay"
  },
  "homepage": "https://ifclite.dev/docs/",
  "bugs": "https://github.com/LTplus-AG/ifc-lite/issues",
  "keywords": [
    "ifc",
    "bim",
    "pdf",
    "underlay",
    "floorplan",
    "georeferencing",
    "calibration",
    "drawing",
    "aec"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
